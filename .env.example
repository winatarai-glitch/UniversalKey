# UniversalKey runtime configuration
# Copy to .env and fill in values for your environment.
# Never commit .env (it is gitignored).

# ── REQUIRED ──────────────────────────────────────────────────────

# Absolute path to your Obsidian vault root.
# Examples:
#   Mac/Linux: /Users/me/Documents/MyVault
#   Windows:   D:\MyVault   or   C:\Users\me\Documents\MyVault
VAULT_PATH=

# Which knowledge domain pack to activate.
# Must match a file in _meta/domain-packs/<name>.md (without the .md).
# Example values: chiropractic, finance, legal, gardening, your-pack-name
ACTIVE_PACK=chiropractic

# ── OPTIONAL ──────────────────────────────────────────────────────

# Path to source corpus to ingest from (used by `extract-from-source.mjs sync`).
# Leave blank if you only use the scaffold + verify verbs.
SOURCE_PATH=

# Path to .ingest-lock sentinel file. Default: ${VAULT_PATH}/_meta/.ingest-lock
# Override only if you split _meta to a separate path.
INGEST_LOCK_PATH=

# Path to derived consumer vault (used by downstream sync engines, e.g. clinical
# packs that produce a curated subset for an EHR or RAG indexer).
DERIVED_VAULT_PATH=

# ── TOOL OVERRIDES (only if not on PATH) ──────────────────────────

# PANDOC_BIN=/usr/local/bin/pandoc
# TESSERACT_BIN=/usr/local/bin/tesseract
# SOFFICE_BIN=/Applications/LibreOffice.app/Contents/MacOS/soffice
# PYTHON_BIN=/usr/bin/python3

# ── OBSERVABILITY ─────────────────────────────────────────────────

LOG_LEVEL=info
